{
    "name": "@liverkp/vue2",
    "version": "0.1.1",
    "description": "Vue 2.7 components for Liver Knowledge Portal (temporary - migrate to @liverkp/vue when possible)",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch"
    },
    "peerDependencies": {
        "vue": "^2.7.0"
    },
    "dependencies": {
        "@liverkp/core": "workspace:*"
    },
    "devDependencies": {
        "@vitejs/plugin-vue2": "^2.3.0",
        "typescript": "^5.3.3",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.7.0",
        "vue": "^2.7.16",
        "vue-tsc": "^1.8.27"
    },
    "keywords": [
        "liverkp",
        "vue",
        "vue2",
        "components"
    ],
    "author": "Broad Institute",
    "license": "BSD-3-Clause",
    "deprecated": "This package targets Vue 2.7+. Migrate to @liverkp/vue (Vue 3) when possible.",
    "repository": {
        "type": "git",
        "url": "https://github.com/broadinstitute/liverkp-assets",
        "directory": "packages/vue2"
    },
    "homepage": "https://github.com/broadinstitute/liverkp-assets#readme",
    "bugs": "https://github.com/broadinstitute/liverkp-assets/issues"
