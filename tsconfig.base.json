{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,

        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,

        /* Paths */
        "baseUrl": ".",
        "paths": {
            "@liverkp/core": ["./packages/core/src"],
            "@liverkp/vue": ["./packages/vue/src"],
            "@liverkp/vue2": ["./packages/vue2/src"],
            "@liverkp/react": ["./packages/react/src"]
        }
    }
}
